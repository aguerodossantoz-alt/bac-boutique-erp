generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum UserRole {
  OWNER
  ADMIN
  MANAGER
  CASHIER
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  displayName  String
  role         UserRole
  store        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Product {
  id            Int      @id @default(autoincrement())
  barcode       String   @unique
  name          String
  article       String?
  promoPrice    Float?
  purchasePrice Float?
  retailPrice   Float?
  stockQty      Int?
  store         String?
  itemStatus    String   @default("READY_FOR_SALE")
  imageUrl      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  saleItems SaleItem[]
}

model Sale {
  id                       Int        @id @default(autoincrement())
  total                    Float
  createdAt                DateTime   @default(now())
  internalReceiptPrintedAt DateTime?
  saleItems                SaleItem[]
}

model SaleItem {
  id        Int     @id @default(autoincrement())
  saleId    Int
  productId Int
  qty       Int
  unitPrice Float
  lineTotal Float
  store     String?

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Expense {
  id                  Int      @id @default(autoincrement())
  title               String
  amount              Float
  category            String
  store               String?
  date                DateTime
  comment             String?
  recurringTemplateId Int?
  recurringMonth      String?
  createdAt           DateTime @default(now())

  recurringTemplate RecurringExpenseTemplate? @relation(fields: [recurringTemplateId], references: [id], onDelete: SetNull)

  @@unique([recurringTemplateId, recurringMonth])
}

model RecurringExpenseTemplate {
  id         Int      @id @default(autoincrement())
  title      String
  amount     Float
  category   String
  store      String?
  comment    String?
  isActive   Boolean  @default(true)
  dayOfMonth Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  expenses Expense[]
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  endpoint  String   @unique
  p256dh    String
  auth      String
  role      String?
  store     String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}